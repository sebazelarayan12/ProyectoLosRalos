POSTGRES_USER=nombre-usuario-postgres
POSTGRES_PASSWORD=password-postgres-segura
POSTGRES_DB=losralos

SEED_ADMIN_EMAIL=email-del-primer-admin
SEED_ADMIN_PASSWORD=password-segura-minimo-12-caracteres
SEED_ADMIN_NOMBRE=nombre-visible-del-admin

# Minimo 32 caracteres aleatorios. Generar con: openssl rand -base64 32
Jwt__Secret=jwt-secret-minimo-32-caracteres-aleatorios

# Minimo 32 caracteres aleatorios, DISTINTO de Jwt__Secret. Generar con: openssl rand -base64 32
Audit__HmacKey=audit-hmac-key-minimo-32-caracteres-distinta-del-jwt-secret

# Origenes permitidos por CORS en produccion (uno por variable, indexados desde 0). Nunca vacio en produccion.
Cors__AllowedOrigins__0=https://dominio-real-del-frontend
